<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Trading Dashboard</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 900px;
      margin: auto;
    }

    h1 {
      margin-bottom: 20px;
    }

    input {
      padding: 10px;
      border-radius: 6px;
      border: none;
      width: 200px;
      color: black;
    }

    button {
      padding: 10px 15px;
      margin-left: 10px;
      border: none;
      border-radius: 6px;
      background: #2563eb;
      color: white;
      cursor: pointer;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      margin-top: 20px;
      border-radius: 10px;
    }

    .signal {
      font-size: 22px;
      font-weight: bold;
    }

    .buy { color: #22c55e; }
    .sell { color: #ef4444; }
    .neutral { color: #facc15; }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 15px;
    }

    .tf {
      background: #334155;
      padding: 10px;
      border-radius: 8px;
    }

    .label {
      color: #94a3b8;
      font-size: 12px;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>📊 Trading Dashboard</h1>

    <!-- INPUT -->
    <input id="symbol" value="EUR/USD" />
    <button onclick="fetchData()">Refresh</button>

    <!-- STATUS -->
    <div id="status"></div>

    <!-- MAIN CARD -->
    <div class="card" id="card" style="display:none;">
      
      <div class="signal" id="signal"></div>

      <p id="prob"></p>

      <h3>Timeframes</h3>
      <div class="grid" id="timeframes"></div>
    </div>
  </div>

<script>
const API_BASE = "https://YOUR-BACKEND-URL.com"; // 🔥 CHANGE THIS

async function fetchData() {
  const symbol = document.getElementById("symbol").value;

  document.getElementById("status").innerHTML = "Loading...";

  try {
    const res = await fetch(`${API_BASE}/process/${symbol}`);
    const data = await res.json();

    document.getElementById("card").style.display = "block";

    // SIGNAL
    const signalEl = document.getElementById("signal");
    signalEl.innerHTML = "Signal: " + data.final_signal;

    signalEl.className = "signal";

    if (data.final_signal === "BUY") {
      signalEl.classList.add("buy");
    } else if (data.final_signal === "SELL") {
      signalEl.classList.add("sell");
    } else {
      signalEl.classList.add("neutral");
    }

    // PROBABILITY
    document.getElementById("prob").innerHTML =
      `Long: ${data.prob_long}% | Short: ${data.prob_short}%`;

    // TIMEFRAMES
    const tfDiv = document.getElementById("timeframes");
    tfDiv.innerHTML = "";

    for (const tf in data.timeframes) {
      const t = data.timeframes[tf];

      tfDiv.innerHTML += `
        <div class="tf">
          <div class="label">${tf}</div>
          <div>Signal: ${t.signal}</div>
          <div>RSI: ${t.rsi}</div>
          <div>ATR: ${t.atr}</div>
          <div>Confidence: ${t.confidence}%</div>
        </div>
      `;
    }

    document.getElementById("status").innerHTML = "";

  } catch (err) {
    console.log(err);
    document.getElementById("status").innerHTML = "Error loading data";
  }
}

// auto refresh every 15 sec
fetchData();
setInterval(fetchData, 15000);
</script>

</body>
</html>
